# .env.live — example environment for live trading (REAL ORDERS!)
#
# ⚠️  WARNING: This configuration will place REAL orders on your exchange.
#     Start with small position sizes and monitor closely.
#
# Copy to .env and fill in all required fields before starting:
#   cp examples/.env.live .env
#   # Edit .env carefully, then:
#   uv run trading-crew

# ── Exchange ──────────────────────────────────────────────────────────────────
EXCHANGE_ID=binance
# API key with spot-trading permissions (read + trade; disable withdrawals).
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# ── Trading mode ──────────────────────────────────────────────────────────────
TRADING_MODE=live

# ── Symbols ───────────────────────────────────────────────────────────────────
SYMBOLS=BTC/USDT

# ── LLM (CrewAI agents) ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Pipeline modes ────────────────────────────────────────────────────────────
# HYBRID uses deterministic signals + LLM analysis for confirmation.
MARKET_PIPELINE_MODE=hybrid
STRATEGY_PIPELINE_MODE=deterministic
EXECUTION_PIPELINE_MODE=deterministic

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///trading.db

# ── Notifications ─────────────────────────────────────────────────────────────
# Strongly recommended for live trading: receive Telegram alerts on fills.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
NOTIFICATION_MIN_LEVEL=info

# ── Risk ──────────────────────────────────────────────────────────────────────
# Conservative defaults — adjust to your risk tolerance.
MAX_POSITION_PCT=0.05
MAX_DRAWDOWN_PCT=0.15
MIN_CONFIDENCE=0.7
STOP_LOSS_MONITORING_ENABLED=true
STOP_LOSS_METHOD=atr

# ── Loop ──────────────────────────────────────────────────────────────────────
LOOP_INTERVAL_SECONDS=300

# ── Dashboard API ─────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
