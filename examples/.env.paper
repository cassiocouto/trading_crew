# .env.paper — example environment for paper-trading (no real orders)
#
# Copy this file to .env in the project root and fill in your API keys.
# Paper mode simulates order fills without touching real funds.
#
# Usage:
#   cp examples/.env.paper .env
#   # edit .env, then:
#   uv run trading-crew

# ── Exchange ──────────────────────────────────────────────────────────────────
EXCHANGE_ID=binance
# Binance API key/secret are optional in paper mode; the system will use
# public endpoints for market data and simulate fills locally.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Trading mode ──────────────────────────────────────────────────────────────
TRADING_MODE=paper

# ── Symbols ───────────────────────────────────────────────────────────────────
SYMBOLS=BTC/USDT,ETH/USDT

# ── LLM (CrewAI agents) ───────────────────────────────────────────────────────
# Set your OpenAI key if you want LLM-powered analysis (CREWAI / HYBRID mode).
# Leave blank to use DETERMINISTIC pipeline mode (no LLM required).
OPENAI_API_KEY=

# ── Pipeline modes ────────────────────────────────────────────────────────────
MARKET_PIPELINE_MODE=deterministic
STRATEGY_PIPELINE_MODE=deterministic
EXECUTION_PIPELINE_MODE=deterministic

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, single-process):
DATABASE_URL=sqlite:///trading.db
# PostgreSQL example (multi-process / Docker):
# DATABASE_URL=postgresql+psycopg2://trader:secret@localhost:5432/trading_crew

# ── Notifications ─────────────────────────────────────────────────────────────
# Optional Telegram bot for trade alerts.  Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Risk ──────────────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.1
MAX_DRAWDOWN_PCT=0.2
MIN_CONFIDENCE=0.6

# ── Dashboard API ─────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
