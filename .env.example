# =============================================================================
# Trading Crew — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Trading Mode -----------------------------------------------------------
# "paper" = simulated orders (default, safe)
# "live"  = real orders on the exchange — use with caution
TRADING_MODE=paper

# --- Exchange Credentials ----------------------------------------------------
# Primary exchange (e.g. binance, novadax, kraken, bybit, etc.)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your-api-key-here
EXCHANGE_API_SECRET=your-api-secret-here

# Optional: exchange-specific password (some exchanges require it)
# EXCHANGE_PASSWORD=

# Optional: use exchange sandbox/testnet
EXCHANGE_SANDBOX=true

# --- Database ----------------------------------------------------------------
# SQLite (default for local dev):
DATABASE_URL=sqlite:///trading_crew.db
# PostgreSQL (recommended for production, uses sync psycopg driver):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trading_crew

# --- Telegram Notifications (optional) --------------------------------------
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here

# --- LLM for CrewAI Agents --------------------------------------------------
# CrewAI requires an LLM backend. Set your preferred provider:
OPENAI_API_KEY=your-openai-key-here
# Or use a local model:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3

# --- Cost Contention / Scheduling --------------------------------------------
# Main loop cadence (default 15 minutes to avoid token-heavy scalping behavior)
LOOP_INTERVAL_SECONDS=900

# Enable cost contention scheduling (recommended)
COST_CONTENTION_ENABLED=true

# Crew-specific run intervals. Crews execute only when due.
MARKET_CREW_INTERVAL_SECONDS=900
STRATEGY_CREW_INTERVAL_SECONDS=1800
EXECUTION_CREW_INTERVAL_SECONDS=900

# Daily token budget guard (estimated usage; provider-reported tokens may differ)
DAILY_TOKEN_BUDGET_ENABLED=true
DAILY_TOKEN_BUDGET_TOKENS=600000

# Degrade mode after budget pressure:
# - off: no degrade behavior
# - strategy_only: disable Strategy crew for rest of UTC day when budget is tight
# - hard_stop: strategy_only, then full LLM hard-stop after budget exhaustion
TOKEN_BUDGET_DEGRADE_MODE=strategy_only

# During hard-stop, run lightweight non-LLM open-order probes each cycle
NON_LLM_MONITOR_ON_HARD_STOP=true

# Estimated token cost per crew run (used for budget accounting)
MARKET_CREW_ESTIMATED_TOKENS=1500
STRATEGY_CREW_ESTIMATED_TOKENS=6000
EXECUTION_CREW_ESTIMATED_TOKENS=1000

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
