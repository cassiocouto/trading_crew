# =============================================================================
# Trading Crew — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Trading Mode -----------------------------------------------------------
# "paper" = simulated orders (default, safe)
# "live"  = real orders on the exchange — use with caution
TRADING_MODE=paper

# --- Exchange Credentials ----------------------------------------------------
# Primary exchange (e.g. binance, novadax, kraken, bybit, etc.)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your-api-key-here
EXCHANGE_API_SECRET=your-api-secret-here

# Optional: exchange-specific password (some exchanges require it)
# EXCHANGE_PASSWORD=

# Optional: use exchange sandbox/testnet (not needed for paper mode —
# paper_mode simulates orders locally; sandbox only affects the API endpoint)
EXCHANGE_SANDBOX=false

# --- Database ----------------------------------------------------------------
# SQLite (default for local dev):
DATABASE_URL=sqlite:///trading_crew.db
# PostgreSQL (recommended for production, uses sync psycopg driver):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trading_crew

# --- Telegram Notifications (optional) --------------------------------------
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here

# --- LLM for CrewAI Agents --------------------------------------------------
# CrewAI requires an LLM backend. Set your preferred provider:
OPENAI_API_KEY=your-openai-key-here
# Or use a local model:
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3

# --- Scheduling ---------------------------------------------------------------
# Main loop cadence (default 15 minutes)
LOOP_INTERVAL_SECONDS=900

# Open-order polling interval (reconcile stale/partially filled orders)
EXECUTION_POLL_INTERVAL_SECONDS=900

# --- Strategy Pipeline --------------------------------------------------------

# Ensemble voting across strategies (default: individual mode)
ENSEMBLE_ENABLED=false
ENSEMBLE_AGREEMENT_THRESHOLD=0.5

# Stop-loss method: "fixed" (percentage) or "atr" (ATR-based, adapts to volatility)
STOP_LOSS_METHOD=fixed
ATR_STOP_MULTIPLIER=2.0

# --- Position Guards ---------------------------------------------------------
# Anti-averaging-down: reject new BUY if entry <= existing stop-loss price.
# Prevents adding to a losing position once it has fallen past the stop floor.
ANTI_AVERAGING_DOWN=true

# Sell guard mode: "none" (disabled) or "break_even" (LIFO break-even check).
# break_even: holds a sell signal until price >= most recent buy's break-even.
# Stop-loss exits bypass this guard entirely — it only applies to signal-driven sells.
SELL_GUARD_MODE=break_even

# Optional minimum profit margin above break-even required before a sell is approved.
# 0.0 = pure break-even (default). e.g. 1.0 = require at least 1% profit above cost.
RISK__MIN_PROFIT_MARGIN_PCT=0.0

# Starting balance for paper trading only — ignored in live mode (exchange wallet is used)
INITIAL_BALANCE_QUOTE=10000.0

# --- Live Wallet Sync (live mode only, ignored in paper mode) ----------------
# How often (seconds) to re-sync portfolio balance from the exchange.
# Set to 0 to disable. Catches deposits and withdrawals made outside the bot.
BALANCE_SYNC_INTERVAL_SECONDS=300
# Send a Telegram alert when the synced balance drifts by this % or more.
BALANCE_DRIFT_ALERT_THRESHOLD_PCT=1.0

# --- Market Intelligence Pipeline ---------------------------------------------
MARKET_DATA_CANDLE_LIMIT=120
# Regime classifier thresholds (atr/price and ema-spread/price)
MARKET_REGIME_VOLATILITY_THRESHOLD=0.03
MARKET_REGIME_TREND_THRESHOLD=0.01

# Optional deterministic sentiment enrichment (Phase 2b)
SENTIMENT_ENABLED=false
SENTIMENT_FEAR_GREED_ENABLED=true
SENTIMENT_FEAR_GREED_WEIGHT=1.0
SENTIMENT_REQUEST_TIMEOUT_SECONDS=5

# --- Advisory Gate (condition-triggered advisory crew) -------------------------
# Enable/disable advisory crew activation
ADVISORY_ENABLED=true
# Uncertainty score threshold [0.0-1.0] — advisory activates at or above
ADVISORY_ACTIVATION_THRESHOLD=0.6
# Estimated tokens per advisory crew run
ADVISORY_ESTIMATED_TOKENS=4000

# Uncertainty score weights (each 0.0-1.0)
UNCERTAINTY_WEIGHT_VOLATILE_REGIME=0.3
UNCERTAINTY_WEIGHT_SENTIMENT_EXTREME=0.2
UNCERTAINTY_WEIGHT_LOW_SENTIMENT_CONFIDENCE=0.2
UNCERTAINTY_WEIGHT_STRATEGY_DISAGREEMENT=0.3
UNCERTAINTY_WEIGHT_DRAWDOWN_PROXIMITY=0.2
UNCERTAINTY_WEIGHT_REGIME_CHANGE=0.3

# Daily token budget guard (advisory-only token accounting)
DAILY_TOKEN_BUDGET_ENABLED=true
DAILY_TOKEN_BUDGET_TOKENS=600000
# Degrade mode: "normal" (advisory allowed) or "budget_stop" (advisory disabled)
TOKEN_BUDGET_DEGRADE_MODE=normal

# --- CrewAI Verbosity --------------------------------------------------------
# When false (default), CrewAI agent/crew/flow console output is routed through
# the logging system. Set to true to see rich panel output in the terminal.
CREWAI_VERBOSE=false

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
