# =============================================================================
# Trading Crew — Secrets Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# This file contains ONLY secrets and connection strings.
# All non-secret settings (trading mode, intervals, risk parameters, etc.)
# are configured in settings.yaml (see settings.yaml.example).
# =============================================================================

# --- Exchange Credentials ----------------------------------------------------
# Required for live trading. Paper mode works without these.
EXCHANGE_API_KEY=your-api-key-here
EXCHANGE_API_SECRET=your-api-secret-here

# Optional: exchange-specific password (some exchanges require it, e.g. OKX)
# EXCHANGE_PASSWORD=

# --- Database ----------------------------------------------------------------
# SQLite (default — no setup required):
DATABASE_URL=sqlite:///trading_crew.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trading_crew

# --- LLM for Advisory Crew --------------------------------------------------
# Required only if advisory_enabled = true in settings.yaml.
# CrewAI uses this key for the advisory agents (Context, Risk, Sentiment).
OPENAI_API_KEY=your-openai-key-here

# Optional: use a local LLM via an OpenAI-compatible server (e.g. Ollama)
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL_NAME=llama3

# --- Telegram Notifications (optional) --------------------------------------
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here

# --- Dashboard API Key (optional) -------------------------------------------
# When set, all REST API requests must include the header: X-API-Key: <value>
# DASHBOARD_API_KEY=your-dashboard-secret-here
